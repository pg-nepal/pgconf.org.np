    <div class="banner-container">
        <div class="overlay"></div>
        <div class="text">
            <h1><span style="color: #007bff; text-shadow: 0px 0px 5px black;">PostgreSQL</span> Conference Nepal</h1>
            <!-- <h2>{{eventOn.strftime('%_d')}} — {{eventTo.strftime('%_d %B, %Y')}}</h2> -->
             <!-- <p>Stay connected for the next event.</p> -->
             <p>Thank You All For Participating 💙</p>
